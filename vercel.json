{
  "build": {
    "env": {
      "PLAYWRIGHT_BROWSERS_PATH": "0"
    }
  },
  "headers": [
    {
      "source": "/components/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/storage/v1/object/public/(.*)",
      "headers": [
        {
          "key": "X-Dummy-Header",
          "value": "dummy"
        }
      ]
    }
  ]
}