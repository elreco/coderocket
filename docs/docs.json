{
  "$schema": "https://mintlify.com/schema.json",
  "name": "CodeRocket Documentation",
  "theme": "mint",
  "logo": {
    "dark": "https://www.coderocket.app/logo-white.png",
    "light": "https://www.coderocket.app/logo-alternate.png"
  },
  "logoLabel": "CodeRocket",
  "favicon": "https://www.coderocket.app/favicon.ico",
