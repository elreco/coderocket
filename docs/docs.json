{
  "$schema": "https://mintlify.com/schema.json",
  "name": "CodeRocket",
  "theme": "mint",
  "logo": {
    "dark": "https://www.coderocket.app/coderocket-full-inverse.png",
    "light": "https://www.coderocket.app/coderocket-full.png",
    "href": "https://coderocket.app"
  },
  "favicon": "https://www.coderocket.app/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Plus Jakarta Sans"
  },
  "colors": {
    "primary": "#6366F1",
    "light": "#6366F1",
    "dark": "#6366F1"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Back to CodeRocket",
      "href": "https://www.coderocket.app"
    },
    "links": [
      {
        "icon": "discord",
        "label": "Discord",
        "href": "https://discord.gg/t7dQgcYJ5t"
      }
    ]
  },
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "https://www.coderocket.app"
  },
  "anchors": [
    {
      "name": "Website",
      "icon": "globe",
      "url": "https://www.coderocket.app"
    },
    {
      "name": "Community",
      "icon": "discord",
      "url": "https://discord.gg/t7dQgcYJ5t"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "quickstart"
        ]
      },
      {
        "group": "GitHub Integration",
        "pages": [
          "github/overview",
          "github/setup",
          "github/synchronization",
          "github/troubleshooting"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/overview",
          "integrations/setup",
          {
            "group": "Supabase",
            "expanded": true,
            "pages": [
              "integrations/supabase",
              "integrations/migrations",
              "integrations/usage",
              "integrations/troubleshooting"
            ]
          },
          {
            "group": "Stripe",
            "pages": [
              "integrations/stripe"
            ]
          },
          {
            "group": "Vercel Blob",
            "pages": [
              "integrations/vercel-blob"
            ]
          },
          {
            "group": "Resend",
            "pages": [
              "integrations/resend"
            ]
          }
        ]
      },
      {
        "group": "Deployment",
        "pages": [
          "deployment/overview",
          "deployment/guide",
          "deployment/managing",
          "deployment/best-practices",
          "deployment/troubleshooting"
        ]
      }
    ]
  },
  "footerSocials": {
    "discord": "https://discord.gg/t7dQgcYJ5t"
  }
}