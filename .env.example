# Core application URLs
NEXT_PUBLIC_APP_URL=http://localhost:4002
NEXT_PUBLIC_CLOUD_URL=https://www.coderocket.app
NEXT_PUBLIC_DOCS_URL=https://docs.coderocket.app

# Public runtime toggles
NEXT_PUBLIC_BILLING_PROVIDER=none
NEXT_PUBLIC_DOMAIN_PROVIDER=none

# Domain configuration
NEXT_PUBLIC_DEPLOYMENT_ROOT_DOMAIN=lvh.me
NEXT_PUBLIC_PREVIEW_ROOT_DOMAIN=preview.lvh.me
NEXT_PUBLIC_WEBCONTAINER_ROOT_DOMAIN=webcontainer.lvh.me

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# AI provider
ANTHROPIC_API_KEY=replace-me

# Builder
BUILDER_API_URL=http://127.0.0.1:3000
NEXT_PUBLIC_BUILDER_API_URL=http://127.0.0.1:3000
BUILDER_HOST=0.0.0.0
BUILDER_PORT=3000
BUILDER_AUTH_TOKEN=
BUILDER_STORAGE_DRIVER=fs
BUILDER_STORAGE_FS_ROOT=.coderocket/builds
BUILDER_TEMP_DIR=.coderocket/tmp

# Optional infrastructure
REDIS_URL=
KV_URL=
INTEGRATION_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_FROM_ADDRESS=CodeRocket <noreply@example.com>
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_AVATAR_API=
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/elreco/coderocket
GOOGLE_SITE_VERIFICATION=

# Optional OAuth integrations
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=

# Optional billing adapter
BILLING_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=

# Optional domain/storage adapters
DOMAIN_PROVIDER=none
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
BLOB_READ_WRITE_TOKEN=
